{
  "mcpServers": {
    "stitch-designer": {
      "command": "npx",
      "args": [
        "-y",
        "@google/stitch-mcp-server"
      ],
      "env": {
        "STITCH_DEFAULT_PLATFORM": "react",
        "STITCH_STYLING_LIBRARY": "tailwindcss",
        "STITCH_COMPONENT_STRATEGY": "design-system-first"
      }
    }
  }
}